<script>
  // ── Desktop ❓ dropdown ─────────────────────────────────
  // ── Guide modal ────────────────────────────────────
  function toggleGuideModal() {
    const modal = document.getElementById('guide-modal');
    if (modal.classList.contains('hidden')) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    } else {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }
  }

  // ── Desktop ❓ dropdown ─────────────────────────────────
  function toggleNavQuestions() {
    const dropdown = document.getElementById('nav-questions-dropdown');
    const isHidden = dropdown.classList.contains('hidden');
    dropdown.classList.toggle('hidden', !isHidden);
  }

  // Paste question into chat input, open widget if needed, close panels
  function openChatWithQuestion(text) {
    // Close desktop dropdown
    const dropdown = document.getElementById('nav-questions-dropdown');
    if (dropdown) dropdown.classList.add('hidden');

    // Close mobile modal
    const modal = document.getElementById('mobile-questions-modal');
    if (modal && !modal.classList.contains('hidden')) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }

    // Ensure chat widget is visible
    const chatWidget = document.getElementById('chat-widget');
    const chatMinimized = document.getElementById('chat-widget-minimized');
    if (chatWidget && (chatWidget.style.display === 'none' || chatWidget.style.display === '')) {
      if (chatMinimized) chatMinimized.style.display = 'none';
      chatWidget.style.display = 'flex';
    }

    // Paste into input and focus
    const input = document.getElementById('chat-input');
    if (input) {
      input.value = text;
      input.focus();
    }
  }

  // ── Mobile FAB modal ───────────────────────────────────
  function toggleMobileQuestions() {
    const modal = document.getElementById('mobile-questions-modal');
    if (modal.classList.contains('hidden')) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    } else {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }
  }

  // Escape key closes both
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      const dropdown = document.getElementById('nav-questions-dropdown');
      if (dropdown && !dropdown.classList.contains('hidden')) toggleNavQuestions();
      const modal = document.getElementById('mobile-questions-modal');
      if (modal && !modal.classList.contains('hidden')) toggleMobileQuestions();
      const guideModal = document.getElementById('guide-modal');
      if (guideModal && !guideModal.classList.contains('hidden')) toggleGuideModal();
    }
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', function(e) {
    const dropdown = document.getElementById('nav-questions-dropdown');
    const btn = document.getElementById('nav-questions-btn');
    if (dropdown && !dropdown.classList.contains('hidden')) {
      if (!dropdown.contains(e.target) && !btn.contains(e.target)) {
        dropdown.classList.add('hidden');
      }
    }
  });
</script>

