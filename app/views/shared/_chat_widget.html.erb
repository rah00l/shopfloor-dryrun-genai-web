<!-- AI Analyst Chat Widget -->
<!-- File: app/views/shared/_chat_widget.html.erb -->

<!-- Main Widget -->
<div id="chat-widget" class="fixed bg-white rounded-lg shadow-2xl flex flex-col z-50 border border-gray-200">

  <!-- Header -->
  <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white flex justify-between items-center flex-shrink-0"
       style="padding: clamp(12px, 3vw, 16px);">
    <div class="flex-1 min-w-0">
      <h3 class="font-bold truncate" style="font-size: clamp(14px, 4vw, 18px);">AI Analyst Assistant</h3>
      <p class="text-blue-100 truncate" style="font-size: clamp(10px, 2.5vw, 12px);">Ask about shop floor procedures</p>
    </div>
    <div class="flex gap-1 flex-shrink-0 ml-2">
      <button id="chat-questions-toggle"
              class="text-white hover:text-blue-200 transition hover:bg-blue-500 px-2 py-1 rounded cursor-pointer"
              style="font-size: clamp(16px, 4vw, 18px); min-height: 44px; min-width: 44px; display: flex; align-items: center; justify-content: center;"
              title="Browse questions">
        ❓
      </button>
      <button id="chat-minimize"
              class="text-white hover:text-blue-200 transition hover:bg-blue-500 px-2 py-1 rounded cursor-pointer"
              style="font-size: clamp(18px, 5vw, 20px); min-height: 44px; min-width: 44px; display: flex; align-items: center; justify-content: center;"
              title="Minimize">
        −
      </button>
      <button id="chat-close"
              class="text-white hover:text-blue-200 transition hover:bg-blue-500 px-2 py-1 rounded cursor-pointer"
              style="font-size: clamp(18px, 5vw, 20px); min-height: 44px; min-width: 44px; display: flex; align-items: center; justify-content: center;"
              title="Close">
        ✕
      </button>
    </div>
  </div>

  <!-- Questions Panel -->
  <div id="chat-questions-panel" class="hidden flex-shrink-0 bg-blue-50 border-b border-blue-200 overflow-y-auto"
       style="max-height: 55%; padding: clamp(10px, 2.5vw, 14px);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
      <p style="font-size: 13px; font-weight: 700; color: #1e40af; margin: 0;">❓ Quick Questions</p>
      <button onclick="toggleQuestionsPanel()"
              style="background: none; border: none; cursor: pointer; color: #6b7280; font-size: 16px; padding: 2px 6px; line-height: 1;"
              title="Close questions">✕</button>
    </div>
    <p style="font-size: 11px; color: #6b7280; margin: 0 0 10px 0;">Click any question to paste it into the chat input.</p>

    <details class="qw-category">
      <summary>📋 Specs &amp; Procedures</summary>
      <div class="qw-grid">
        <button class="qw-btn" onclick="pasteQuestion('What is the torque spec for the door hinge bracket?')">What is the torque spec for the door hinge bracket?</button>
        <button class="qw-btn" onclick="pasteQuestion('What are the steps to install the door hinge bracket?')">What are the steps to install the door hinge bracket?</button>
        <button class="qw-btn" onclick="pasteQuestion('How often should the Station 4 fixture be recalibrated?')">How often should the Station 4 fixture be recalibrated?</button>
        <button class="qw-btn" onclick="pasteQuestion('What tools are needed for the tensioner inspection?')">What tools are needed for the tensioner inspection?</button>
        <button class="qw-btn" onclick="pasteQuestion('How much belt deflection is acceptable during tensioner inspection?')">How much belt deflection is acceptable during tensioner inspection?</button>
        <button class="qw-btn" onclick="pasteQuestion('Is there an active quality alert for the bracket?')">Is there an active quality alert for the bracket?</button>
      </div>
    </details>

    <details class="qw-category">
      <summary>📋 When No Match Is Found</summary>
      <div class="qw-grid">
        <button class="qw-btn" onclick="pasteQuestion('What happens if no document matches my question?')">What happens if no document matches my question?</button>
        <button class="qw-btn" onclick="pasteQuestion('Will the assistant guess an answer if unsure?')">Will the assistant guess an answer if unsure?</button>
        <button class="qw-btn" onclick="pasteQuestion('How is confidence determined?')">How is confidence determined?</button>
      </div>
    </details>

    <details class="qw-category">
      <summary>📋 Incidents &amp; Root Cause</summary>
      <div class="qw-grid">
        <button class="qw-btn" onclick="pasteQuestion('Why did the bracket thickness change?')">Why did the bracket thickness change?</button>
        <button class="qw-btn" onclick="pasteQuestion('What caused the Line 2 bracket flex issue?')">What caused the Line 2 bracket flex issue?</button>
        <button class="qw-btn" onclick="pasteQuestion('Is there a known issue with the Line 5 conveyor?')">Is there a known issue with the Line 5 conveyor?</button>
      </div>
    </details>

    <details class="qw-category">
      <summary>📋 Try Auto-SOP Generation</summary>
      <div class="qw-grid">
        <button class="qw-btn" onclick="pasteQuestion('ECN-2291: bracket thickness increased from 2mm to 2.5mm on Model AX-500.')">ECN-2291: bracket thickness increased from 2mm to 2.5mm on Model AX-500.</button>
        <button class="qw-btn" onclick="pasteQuestion('What is the torque specification for door hardware, model AX-500?')">What is the torque specification for door hardware, model AX-500?</button>
        <button class="qw-btn" onclick="pasteQuestion('What caused the Line 2 stoppage in RCA-2026-014?')">What caused the Line 2 stoppage in RCA-2026-014?</button>
      </div>
    </details>
  </div>

  <!-- Messages Container -->
  <div id="chat-messages"
       class="flex-1 overflow-y-auto bg-gray-50 space-y-2"
       style="padding: clamp(12px, 3vw, 16px);">
    <div class="flex justify-start">
      <div class="bg-white text-gray-800 rounded-lg shadow-sm border border-gray-200"
           style="padding: clamp(10px, 2.5vw, 12px); max-width: 85%;">
        <p class="font-medium text-gray-700" style="font-size: clamp(12px, 3vw, 14px);">Welcome! 👋</p>
        <p class="text-gray-600 mt-1" style="font-size: clamp(11px, 2.5vw, 12px); line-height: 1.4;">
          I can help you find SOPs, torque specs, maintenance schedules, and root cause reports.
          Tap <strong>❓</strong> above to browse example questions, or type your own below.
        </p>
      </div>
    </div>
  </div>

  <!-- Loading indicator -->
  <div id="chat-loading" class="hidden px-4 py-2 text-center flex-shrink-0">
    <div class="flex items-center justify-center gap-2">
      <div class="w-2 h-2 bg-blue-500 rounded-full animate-bounce"></div>
      <div class="w-2 h-2 bg-blue-500 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
      <div class="w-2 h-2 bg-blue-500 rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
    </div>
  </div>

  <!-- Input Section -->
  <div class="border-t bg-white flex-shrink-0"
       style="padding: clamp(12px, 3vw, 16px); border-radius: 0 0 16px 16px;">
    <form id="chat-form" class="flex gap-2">
      <input
        type="text"
        id="chat-input"
        placeholder="Type your question..."
        class="flex-1 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
        style="font-size: clamp(13px, 3vw, 14px);"
        autocomplete="off"
      />
      <button
        type="submit"
        id="chat-send"
        class="bg-blue-600 hover:bg-blue-700 text-white font-medium transition flex-shrink-0"
        style="
          padding: clamp(8px, 2vw, 10px) clamp(12px, 3vw, 16px);
          font-size: clamp(12px, 3vw, 14px);
          border-radius: 6px;
          min-height: 44px;
          min-width: 44px;
          display: flex;
          align-items: center;
          justify-content: center;
        "
      >
        <span class="hidden sm:inline">Send</span>
        <span class="sm:hidden">→</span>
      </button>
    </form>
  </div>
</div>

<!-- Minimized Bubble -->
<div id="chat-widget-minimized"
     class="hidden fixed bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg shadow-2xl cursor-pointer hover:shadow-xl transition"
     style="z-index: 9999;">
  <div onclick="expandChat()" style="display: flex; flex-direction: column; gap: 4px; align-items: center; padding: clamp(10px, 2.5vw, 12px);">
    <p style="font-size: clamp(18px, 5vw, 24px); margin: 0;">💬</p>
    <p style="font-size: clamp(10px, 2.5vw, 11px); font-weight: 600; margin: 0; white-space: nowrap;">AI Asst</p>
  </div>
  <button id="chat-minimize-close"
          class="absolute text-white hover:text-blue-100 transition"
          style="top: 4px; right: 4px; font-size: 12px; cursor: pointer; background: none; border: none; padding: 2px 4px;"
          onclick="event.stopPropagation(); closeChat()"
          title="Close">✕</button>
</div>

<script>
  // ============================================
  // QUESTIONS PANEL
  // ============================================

  function toggleQuestionsPanel() {
    const panel = document.getElementById('chat-questions-panel');
    const isHidden = panel.classList.contains('hidden');
    panel.classList.toggle('hidden', !isHidden);
    if (isHidden) {
      const msgs = document.getElementById('chat-messages');
      if (msgs) msgs.scrollTop = msgs.scrollHeight;
    }
  }

  function pasteQuestion(text) {
    const input = document.getElementById('chat-input');
    if (input) {
      input.value = text;
      input.focus();
      const panel = document.getElementById('chat-questions-panel');
      if (panel) panel.classList.add('hidden');
    }
  }

  // ============================================
  // UTILITY FUNCTIONS
  // ============================================

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function generateSessionId() {
    const timestamp = Date.now();
    const random = Math.random().toString(36).substr(2, 9);
    return `session_${timestamp}_${random}`;
  }

  function getCsrfTokenGlobal() {
    return document.querySelector('meta[name="csrf-token"]')?.content || '';
  }

  // ============================================
  // FEEDBACK LOOP — operator flags an answer as accurate or not
  // ============================================

  window.submitFeedback = function(elementId, wasAccurate, answerText) {
    const el = document.getElementById(elementId);
    if (el) {
      el.innerHTML = '<span style="font-size:10px;color:#166534;">&#10003; Thanks &mdash; feedback recorded</span>';
    }
    fetch('/chat/feedback', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfTokenGlobal() },
      body: JSON.stringify({ question: answerText, rating: wasAccurate ? 'up' : 'down' })
    }).catch(function(e) { console.error('Feedback failed:', e); });
  };

  // ============================================
  // REFERENCE CARDS — doc type, section, match strength
  // ============================================

  function docTypeInfo(filename) {
    const prefix = filename.split('-')[0].replace(/^\d+/, '');
    const map = {
      SOP: { icon: '📋', label: 'Procedure', color: '#1e40af', bg: '#eff6ff' },
      WI:  { icon: '📐', label: 'Work Instruction', color: '#1e40af', bg: '#eff6ff' },
      MM:  { icon: '🔧', label: 'Maintenance', color: '#854d0e', bg: '#fefce8' },
      QA:  { icon: '⚠️', label: 'Quality Alert', color: '#166534', bg: '#f0fdf4' },
      ECN: { icon: '📝', label: 'Change Notice', color: '#166534', bg: '#f0fdf4' },
      RCA: { icon: '🔍', label: 'Root Cause', color: '#166534', bg: '#f0fdf4' }
    };
    return map[prefix] || { icon: '📄', label: 'Document', color: '#374151', bg: '#f3f4f6' };
  }

  function matchStrength(distance) {
    const pct = Math.max(0, Math.min(100, Math.round((1 - distance / 0.7) * 100)));
    const label = pct >= 65 ? 'Strong match' : 'Good match';
    return { pct: pct, label: label };
  }

  // Overall answer confidence, derived from the best (lowest) retrieval
  // distance among the returned sources. This is deliverable 4 —
  // "traceability + confidence scoring" — made visible in the UI.
  function overallConfidence(sources) {
    if (!sources || sources.length === 0) return null;
    const best = Math.min.apply(null, sources.map(function(s) { return s.distance; }));
    if (best < 0.35) {
      return { label: 'High confidence', color: '#166534', bg: '#f0fdf4', border: '#bbf7d0' };
    } else if (best < 0.55) {
      return { label: 'Medium confidence', color: '#854d0e', bg: '#fefce8', border: '#fde68a' };
    } else {
      return { label: 'Low confidence', color: '#92400e', bg: '#fff7ed', border: '#fed7aa' };
    }
  }

  // RAG (fresh retrieval) vs CAG (served from cache) — deliverable 1,
  // made visible per-answer instead of only living in the architecture diagram.
  function retrievalModeBadge(fromCache) {
    if (fromCache) {
      return '<span style="display:inline-flex;align-items:center;gap:3px;background:#fefce8;color:#854d0e;border:1px solid #fde68a;font-size:9.5px;font-weight:600;padding:2px 7px;border-radius:10px;">⚡ CAG cache</span>';
    }
    return '<span style="display:inline-flex;align-items:center;gap:3px;background:#eff6ff;color:#1e40af;border:1px solid #bfdbfe;font-size:9.5px;font-weight:600;padding:2px 7px;border-radius:10px;">🔍 RAG retrieval</span>';
  }

  function renderAnswerWithReferences(data) {
    const hasSources = data.sources && data.sources.length > 0;
    const confidence = overallConfidence(data.sources);

    const citedBadge = hasSources
      ? '<span style="display:inline-flex;align-items:center;gap:3px;background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;font-size:9.5px;font-weight:600;padding:2px 7px;border-radius:10px;">✓ Cited</span>'
      : '<span style="display:inline-flex;align-items:center;gap:3px;background:#fffbeb;color:#92400e;border:1px solid #fde68a;font-size:9.5px;font-weight:600;padding:2px 7px;border-radius:10px;">⚠ Not found</span>';

    const modeBadge = retrievalModeBadge(data.from_cache);

    const confidenceBadge = confidence
      ? '<span style="display:inline-flex;align-items:center;gap:3px;background:' + confidence.bg + ';color:' + confidence.color + ';border:1px solid ' + confidence.border + ';font-size:9.5px;font-weight:600;padding:2px 7px;border-radius:10px;">' + confidence.label + '</span>'
      : '';

    const badgeRow = '<div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px;">' + citedBadge + modeBadge + confidenceBadge + '</div>';

    const answerText = escapeHtml(data.explanation || '');

    let refsHtml = '';
    if (hasSources) {
      const cards = data.sources.map(function(src) {
        const info = docTypeInfo(src.document);
        const match = matchStrength(src.distance);
        return '<div style="display:flex;align-items:center;gap:8px;background:' + info.bg + ';border:1px solid ' + info.color + '22;border-radius:8px;padding:6px 10px;margin-top:6px;">' +
          '<span style="font-size:14px;">' + info.icon + '</span>' +
          '<div style="flex:1;min-width:0;">' +
            '<div style="font-size:11px;font-weight:600;color:' + info.color + ';">' + info.label + ' &middot; ' + escapeHtml(src.document) + '</div>' +
            '<div style="font-size:10.5px;color:#6b7280;">' + escapeHtml(src.section) + '</div>' +
          '</div>' +
          '<div style="font-size:9.5px;font-weight:600;color:' + info.color + ';white-space:nowrap;">' + match.label + '</div>' +
        '</div>';
      }).join('');

      refsHtml = '<details style="margin-top:8px;">' +
        '<summary style="font-size:10.5px;font-weight:600;color:#6b7280;cursor:pointer;">📎 View sources (' + data.sources.length + ')</summary>' +
        cards +
      '</details>';
    }

    const feedbackId = 'fb-' + Math.random().toString(36).substr(2, 9);
    const safeAnswerJson = JSON.stringify(data.explanation || '');
    const feedbackHtml = '<div id="' + feedbackId + '" style="margin-top:8px;display:flex;align-items:center;gap:8px;">' +
      '<span style="font-size:10px;color:#9ca3af;">Was this accurate?</span>' +
      '<button onclick=\'submitFeedback("' + feedbackId + '", true, ' + safeAnswerJson + ')\' style="background:none;border:1px solid #e5e7eb;border-radius:5px;padding:2px 7px;cursor:pointer;font-size:11px;">👍</button>' +
      '<button onclick=\'submitFeedback("' + feedbackId + '", false, ' + safeAnswerJson + ')\' style="background:none;border:1px solid #e5e7eb;border-radius:5px;padding:2px 7px;cursor:pointer;font-size:11px;">👎</button>' +
    '</div>';

    return badgeRow + '<div style="font-size:13px;line-height:1.5;">' + answerText + '</div>' + refsHtml + feedbackHtml;
  }

  // ============================================
  // UI CONTROL FUNCTIONS
  // ============================================

  function minimizeChat() {
    const chatWidget = document.getElementById('chat-widget');
    const chatMinimized = document.getElementById('chat-widget-minimized');
    chatWidget.style.display = 'none';
    chatMinimized.classList.remove('hidden');
    chatMinimized.classList.remove('force-hidden');
    chatMinimized.style.cssText = 'display:block !important; position:fixed !important; bottom:20px !important; right:20px !important; z-index:9999 !important;';
  }

  function expandChat() {
    const chatWidget = document.getElementById('chat-widget');
    const chatMinimized = document.getElementById('chat-widget-minimized');
    chatMinimized.classList.add('hidden');
    chatMinimized.classList.add('force-hidden');
    chatMinimized.style.display = 'none';
    chatWidget.style.display = 'flex';
    const input = document.getElementById('chat-input');
    if (input) input.focus();
  }

  function closeChat() {
    const chatWidget = document.getElementById('chat-widget');
    const chatMinimized = document.getElementById('chat-widget-minimized');
    chatWidget.style.display = 'none';
    chatMinimized.classList.add('hidden');
    chatMinimized.style.display = 'none';
  }

  // ============================================
  // INITIALIZATION
  // ============================================

  document.addEventListener('DOMContentLoaded', function() {
    const chatForm = document.getElementById('chat-form');
    const chatInput = document.getElementById('chat-input');
    const chatMessages = document.getElementById('chat-messages');
    const chatLoading = document.getElementById('chat-loading');
    const chatMinimizeBtn = document.getElementById('chat-minimize');
    const chatCloseBtn = document.getElementById('chat-close');
    const chatQuestionsToggle = document.getElementById('chat-questions-toggle');
    const chatWidget = document.getElementById('chat-widget');
    const chatMinimized = document.getElementById('chat-widget-minimized');

    let currentSessionId = null;

    // ── Mobile auto-minimise ──────────────────────────────
    // On screens < 640px: start as bubble, not open widget
    if (window.innerWidth < 640) {
      chatWidget.style.display = 'none';
      chatMinimized.classList.remove('hidden');
      chatMinimized.style.cssText = 'display:block !important; position:fixed !important; bottom:20px !important; right:20px !important; z-index:9999 !important;';
    } else {
      // Non-mobile: focus input as normal
      if (chatInput) chatInput.focus();
    }
    // ─────────────────────────────────────────────────────

    function getCsrfToken() {
      const token = document.querySelector('meta[name="csrf-token"]')?.content;
      if (!token) console.warn('CSRF token not found');
      return token || '';
    }

    function getFileId() {
      const urlParams = new URLSearchParams(window.location.search);
      const fileIdFromUrl = urlParams.get('file_id');
      if (fileIdFromUrl) return fileIdFromUrl;
      const fileIdFromAttr = document.querySelector('[data-file-id]')?.dataset.fileId;
      if (fileIdFromAttr) return fileIdFromAttr;
      const pathMatch = window.location.pathname.match(/\/payment_files\/(\d+)/);
      return pathMatch ? pathMatch[1] : null;
    }

    function addMessage(text, sender, isHtml = false) {
      if (!text) return;
      const messageEl = document.createElement('div');
      messageEl.className = sender === 'user' ? 'flex justify-end' : 'flex justify-start';
      const bubbleEl = document.createElement('div');
      if (sender === 'user') {
        bubbleEl.className = 'bg-blue-600 text-white rounded-lg shadow-sm';
        bubbleEl.style.cssText = 'padding: clamp(8px, 2vw, 12px); max-width: 85%;';
      } else {
        bubbleEl.className = 'bg-white text-gray-800 rounded-lg shadow-sm border border-gray-200';
        bubbleEl.style.cssText = 'padding: clamp(8px, 2vw, 12px); max-width: 85%;';
      }
      if (isHtml) {
        bubbleEl.innerHTML = text;
      } else {
        bubbleEl.innerHTML = `<p style="font-size: clamp(12px, 3vw, 14px); margin: 0;">${escapeHtml(text)}</p>`;
      }
      messageEl.appendChild(bubbleEl);
      chatMessages.appendChild(messageEl);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    chatForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const question = chatInput.value.trim();
      if (!question) return;
      if (!currentSessionId) currentSessionId = generateSessionId();
      const fileId = getFileId();
      addMessage(question, 'user', false);
      chatInput.value = '';
      chatInput.focus();
      chatLoading.classList.remove('hidden');
      try {
        const payload = { question: question, session_id: currentSessionId };
        if (fileId) payload.file_id = fileId;
        const response = await fetch('/chat/analyze', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrfToken() },
          body: JSON.stringify(payload)
        });
        chatLoading.classList.add('hidden');
        if (!response.ok) {
          addMessage('Server error. Please try again.', 'assistant', false);
          return;
        }
        const data = await response.json();
        if (!data) { addMessage('No response received. Please try again.', 'assistant', false); return; }

        const answerHtml = renderAnswerWithReferences(data);
        addMessage(answerHtml, 'assistant', true);

        if (data.session_id) currentSessionId = data.session_id;
      } catch (error) {
        chatLoading.classList.add('hidden');
        console.error('Chat error:', error);
        addMessage(`Network error: ${error.message}`, 'assistant', false);
      }
    });

    chatMinimizeBtn.addEventListener('click', minimizeChat);
    chatCloseBtn.addEventListener('click', closeChat);
    chatQuestionsToggle.addEventListener('click', toggleQuestionsPanel);
  });
</script>

<style>
  /* ============================================
     MOBILE DEFAULT (< 640px)
     Widget hidden, bubble visible — pure CSS
     guarantees correct state before JS runs
     ============================================ */

  @media (max-width: 639px) {
    #chat-widget {
      display: none;
    }
    #chat-widget-minimized:not(.force-hidden) {
      display: block !important;
      position: fixed !important;
      bottom: 20px !important;
      right: 20px !important;
      z-index: 9999 !important;
    }
    #chat-widget-minimized.force-hidden {
      display: none !important;
    }
  }

  /* ============================================
     RESPONSIVE LAYOUT
     ============================================ */

  #chat-widget {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: 68vh;
    max-height: 68vh;
    border-radius: 16px 16px 0 0;
    z-index: 50;
    display: flex;
    flex-direction: column;
    border: none;
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.15);
  }

  #chat-widget-minimized {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: auto;
    z-index: 9999;
  }

  @media (min-width: 640px) {
    #chat-widget {
      bottom: 0;
      left: 0;
      right: 0;
      width: 100%;
      height: 60vh;
      max-height: 60vh;
      border-radius: 16px 16px 0 0;
      z-index: 50;
    }
    #chat-widget-minimized {
      bottom: 20px;
      right: 20px;
    }
  }

  @media (min-width: 768px) {
    #chat-widget {
      bottom: 16px;
      right: 16px;
      left: auto;
      width: 380px;
      height: 520px;
      max-height: 520px;
      border-radius: 12px;
      border: 1px solid #e5e7eb;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
      z-index: 40;
    }
