<!-- Copy to Clipboard Function -->
<script>
  function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
      // Optional: Show feedback
      alert('Question copied: ' + text);
    }).catch(err => {
      console.error('Failed to copy:', err);
    });
  }
</script>
